# API URL for the frontend (usually not needed for Next.js API routes)
NEXT_PUBLIC_API_URL=

# AI Configuration - Choose one of the following methods:

# Method 1: OpenRouter API (Recommended - Free tier available)
# Get a free API key from: https://openrouter.ai/activity?api_key_id=16078015
# Free tier: 2000 tokens/day, supports multiple models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Method 2: HuggingFace Inference API (Alternative)
# Get a free API key from: https://huggingface.co/settings/tokens
# Free tier: Limited requests per day
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Method 3: Local AI (No API key needed - Rule-based generation)
# Set to 'true' to use local text analysis instead of external AI APIs
# This method doesn't require any API keys but may generate simpler questions
USE_LOCAL_AI=true

# Legacy: Generic AI API Key (will default to OpenRouter)
# This is used if neither OPENROUTER_API_KEY nor HUGGINGFACE_API_KEY are set
AI_API_KEY=your_generic_ai_api_key_here

# Available free models:
# - OpenRouter: mistralai/mistral-7b-instruct:free (recommended)
# - OpenRouter: google/gemma-2-9b-it:free
# - OpenRouter: meta-llama/llama-3.2-1b-instruct:free
# - HuggingFace: mistralai/Mistral-7B-Instruct-v0.2

# Configuration examples:
# Example 1: Use OpenRouter (recommended)
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Example 2: Use HuggingFace
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Example 3: Use Local AI (no API key needed)
# USE_LOCAL_AI=true
