# API URL for the frontend (usually not needed for Next.js API routes)
NEXT_PUBLIC_API_URL=

# AI API Key for free AI model (OpenRouter API) - RECOMMENDED
# Get a free API key from: https://openrouter.ai/activity?api_key_id=16078015
# Free tier: 2000 tokens/day, supports multiple models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alternative: HuggingFace Inference API
# Get a free API key from: https://huggingface.co/settings/tokens
# Free tier: Limited requests per day
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Legacy: Generic AI API Key (will default to OpenRouter)
# This is used if neither OPENROUTER_API_KEY nor HUGGINGFACE_API_KEY are set
AI_API_KEY=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

# Available free models:
# - OpenRouter: mistralai/mistral-7b-instruct:free (recommended)
# - OpenRouter: google/gemma-2-9b-it:free
# - OpenRouter: meta-llama/llama-3.2-1b-instruct:free
# - HuggingFace: mistralai/Mistral-7B-Instruct-v0.2
