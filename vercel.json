{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff|woff2|ttf|eot|svg|jpg|jpeg|png|gif|ico|webp)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000"
        }
      ]
    }
  ],

  "env": {
    "NEXT_PUBLIC_APP_NAME": "Quiz AI",
    "NEXT_PUBLIC_APP_VERSION": "1.0.0"
  },

  "regions": ["iad1"],

  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  }
}