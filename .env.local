# AI Configuration
# This app uses LOCAL AI (no external APIs required)
# The AI runs entirely in the browser and serverless functions

# Set to true to force local AI mode (recommended)
USE_LOCAL_AI=true

# No external API keys needed - everything runs locally!

# Optional Configuration
API_BASE_URL=http://localhost:3000/api
MAX_FILE_SIZE=10485760
TIMEOUT_DURATION=30000
