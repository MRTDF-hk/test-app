# AI Configuration
# Choose one of the following AI providers:

# Option 1: OpenRouter (Recommended - Free tier available)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Option 2: HuggingFace Inference API
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Option 3: Generic AI API Key (fallback)
# AI_API_KEY=your_generic_ai_api_key_here

# Option 4: Local AI (No external API required - limited functionality)
# USE_LOCAL_AI=true

# Optional Configuration
# API_BASE_URL=http://localhost:3000/api
# MAX_FILE_SIZE=10485760
# TIMEOUT_DURATION=30000